@model ElectronicaVallarta.Dominio.Entidades.TasaCambioRango
@{
    ViewData["Title"] = "Eliminar tasa";
}
<section class="space-y-6">
    <partial name="~/Views/Shared/_BarraAdministracion.cshtml" />

    <div class="mx-auto max-w-2xl rounded-[2rem] border border-white/70 bg-white/90 p-8 shadow-panel">
        <p class="text-xs font-bold uppercase tracking-[0.25em] text-rose-600">Confirmacion</p>
        <h1 class="mt-2 text-3xl font-black text-tinta">Eliminar tasa</h1>
        <p class="mt-4 text-sm leading-7 text-slate-600">Eliminaras la tasa de <strong>@Model.Pais?.Nombre</strong> en <strong>@Model.Sucursal?.Nombre</strong> para la fecha <strong>@Model.FechaTasa.ToString("dd/MM/yyyy")</strong>.</p>
        <form asp-action="Eliminar" method="post" class="mt-8 flex flex-wrap gap-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="rounded-2xl bg-rose-600 px-5 py-3 text-sm font-bold uppercase tracking-[0.2em] text-white transition hover:bg-rose-700">Eliminar</button>
            <a asp-action="Index" class="rounded-2xl border border-slate-200 px-5 py-3 text-sm font-bold uppercase tracking-[0.2em] text-slate-700">Cancelar</a>
        </form>
    </div>
</section>
