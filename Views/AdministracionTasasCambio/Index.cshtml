@model ElectronicaVallarta.ViewModels.ListadoTasasCambioViewModel

@{
    ViewData["Title"] = "Tasas de cambio";
}

<partial name="~/Views/Shared/_Mensajes.cshtml" />

<section class="space-y-6">
    <partial name="~/Views/Shared/_BarraAdministracion.cshtml" />

    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div>
            <p class="text-xs font-bold uppercase tracking-[0.25em] text-mar">Operacion diaria</p>
            <h1 class="mt-2 text-3xl font-black text-tinta">Tasas por rango</h1>
            <p class="mt-2 text-sm leading-7 text-slate-600">Configuracion por fecha, pais, sucursal y monto en USD.</p>
        </div>
        <a asp-action="Crear" class="inline-flex items-center justify-center rounded-2xl bg-tinta px-5 py-3 text-sm font-bold uppercase tracking-[0.2em] text-white transition hover:bg-mar">Nueva tasa</a>
    </div>

    <form method="get" class="rounded-[2rem] border border-white/70 bg-white/90 p-5 shadow-panel">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div class="w-full flex-1 space-y-2">
                <label for="fechaFiltro" class="text-sm font-semibold text-slate-700">Filtrar por fecha</label>
                <input id="fechaFiltro" name="fechaFiltro" type="date" value="@(Model.FechaFiltro?.ToString("yyyy-MM-dd"))" onchange="this.form.submit()" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 outline-none transition focus:border-mar focus:ring-4 focus:ring-mar/10" />
            </div>
            <div class="flex flex-row flex-nowrap items-end gap-3 lg:shrink-0">
                <a asp-action="Index" asp-route-mostrarTodos="true" class="rounded-2xl border border-slate-200 px-5 py-3 text-sm font-bold uppercase tracking-[0.2em] text-slate-700 transition hover:bg-slate-50">Ver todos</a>
                <a asp-action="Index" class="rounded-2xl border border-slate-200 px-5 py-3 text-sm font-bold uppercase tracking-[0.2em] text-slate-700 transition hover:bg-slate-50">Hoy</a>
            </div>
        </div>
    </form>

    <div class="overflow-hidden rounded-[2rem] border border-white/70 bg-white/90 shadow-panel">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 text-sm">
                <thead class="bg-slate-50/80">
                    <tr class="text-left text-xs font-bold uppercase tracking-[0.2em] text-slate-500">
                        <th class="px-6 py-4">Fecha</th>
                        <th class="px-6 py-4">Pais</th>
                        <th class="px-6 py-4">Sucursal</th>
                        <th class="px-6 py-4">Rango USD</th>
                        <th class="px-6 py-4">Tasa</th>
                        <th class="px-6 py-4">Estado</th>
                        <th class="px-6 py-4 text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                @foreach (var tasa in Model.Tasas)
                {
                    <tr class="hover:bg-slate-50/70">
                        <td class="px-6 py-4 text-slate-600">@tasa.FechaTasa.ToString("MM/dd/yyyy")</td>
                        <td class="px-6 py-4 text-slate-700">@tasa.NombrePais</td>
                        <td class="px-6 py-4 font-semibold text-tinta">@tasa.NombreSucursal</td>
                        <td class="px-6 py-4 text-slate-600">@tasa.MontoDesdeUsd.ToString("N2") - @(tasa.MontoHastaUsd.HasValue ? tasa.MontoHastaUsd.Value.ToString("N2") : "En adelante")</td>
                        <td class="px-6 py-4 text-slate-700">@tasa.TasaCambio.ToString("N4")</td>
                        <td class="px-6 py-4">
                            <span class="rounded-full px-3 py-1 text-xs font-bold uppercase tracking-[0.15em] @(tasa.EstaActivo ? "bg-emerald-100 text-emerald-700" : "bg-slate-200 text-slate-600")">@(tasa.EstaActivo ? "Activo" : "Inactivo")</span>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex justify-end gap-2">
                                <a asp-action="Editar" asp-route-id="@tasa.Id" class="rounded-xl border border-slate-200 px-4 py-2 font-semibold text-slate-700 transition hover:border-mar hover:text-mar">Editar</a>
                                <a asp-action="Eliminar" asp-route-id="@tasa.Id" class="rounded-xl border border-rose-200 px-4 py-2 font-semibold text-rose-700 transition hover:bg-rose-50">Eliminar</a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Tasas.Any())
                {
                    <tr>
                        <td colspan="7" class="px-6 py-8 text-center text-sm text-slate-500">
                            @(Model.MostrarTodos
                                ? "No se encontraron tasas registradas."
                                : "No se encontraron tasas para la fecha seleccionada.")
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</section>
