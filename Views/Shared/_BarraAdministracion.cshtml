<div class="flex flex-wrap items-center gap-3 rounded-[1.75rem] border border-white/70 bg-white/85 p-4 shadow-panel">
    <a asp-controller="Administracion" asp-action="Index" class="rounded-full bg-tinta px-4 py-2 text-sm font-bold text-white transition hover:bg-mar">
        Menu administracion
    </a>
    <a asp-controller="AdministracionPaises" asp-action="Index" class="rounded-full border border-borde bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-mar hover:text-mar">
        Paises
    </a>
    <a asp-controller="AdministracionSucursales" asp-action="Index" class="rounded-full border border-borde bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-mar hover:text-mar">
        Sucursales
    </a>
    <a asp-controller="AdministracionTasasCambio" asp-action="Index" class="rounded-full border border-borde bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-mar hover:text-mar">
        Tasas
    </a>
    <div class="ml-auto flex flex-wrap items-center gap-3">
        <a asp-controller="Home" asp-action="Index" class="rounded-full border border-borde bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-azulClaroMarca hover:text-azulMarca">
            Vista publica
        </a>
        <form asp-controller="Cuenta" asp-action="Salir" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="rounded-full bg-rojoMarca px-4 py-2 text-sm font-bold text-white transition hover:bg-red-700">
                Salir
            </button>
        </form>
    </div>
</div>
