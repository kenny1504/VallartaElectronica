@if (TempData["MensajeExito"] is string mensajeExito)
{
    <div class="toast-notificacion toast-exito" data-toast>
        <div class="min-w-0">
            <p class="text-xs font-black uppercase tracking-[0.2em] text-emerald-700">Exito</p>
            <p class="mt-1 text-sm leading-6 text-slate-700">@mensajeExito</p>
        </div>
        <button type="button" class="toast-cerrar" data-toast-cerrar aria-label="Cerrar notificacion">×</button>
    </div>
}

@if (TempData["MensajeError"] is string mensajeError)
{
    <div class="toast-notificacion toast-error" data-toast>
        <div class="min-w-0">
            <p class="text-xs font-black uppercase tracking-[0.2em] text-rose-700">Error</p>
            <p class="mt-1 text-sm leading-6 text-slate-700">@mensajeError</p>
        </div>
        <button type="button" class="toast-cerrar" data-toast-cerrar aria-label="Cerrar notificacion">×</button>
    </div>
}
