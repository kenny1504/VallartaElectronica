@model IEnumerable<ElectronicaVallarta.Dominio.Entidades.Pais>

@{
    ViewData["Title"] = "Paises";
}

<partial name="~/Views/Shared/_Mensajes.cshtml" />

<section class="space-y-6">
    <partial name="~/Views/Shared/_BarraAdministracion.cshtml" />

    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div>
            <p class="text-xs font-bold uppercase tracking-[0.25em] text-mar">Catalogo</p>
            <h1 class="mt-2 text-3xl font-black text-tinta">Paises</h1>
            <p class="mt-2 text-sm leading-7 text-slate-600">Destinos habilitados para la calculadora de envio.</p>
        </div>
        <a asp-action="Crear" class="inline-flex items-center justify-center rounded-2xl bg-tinta px-5 py-3 text-sm font-bold uppercase tracking-[0.2em] text-white transition hover:bg-mar">Nuevo pais</a>
    </div>

    <div class="overflow-hidden rounded-[2rem] border border-white/70 bg-white/90 shadow-panel">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 text-sm">
                <thead class="bg-slate-50/80">
                    <tr class="text-left text-xs font-bold uppercase tracking-[0.2em] text-slate-500">
                        <th class="px-6 py-4">Nombre</th>
                        <th class="px-6 py-4">Moneda</th>
                        <th class="px-6 py-4">Simbolo</th>
                        <th class="px-6 py-4">Estado</th>
                        <th class="px-6 py-4 text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                @foreach (var pais in Model)
                {
                    <tr class="hover:bg-slate-50/70">
                        <td class="px-6 py-4 font-semibold text-tinta">@pais.Nombre</td>
                        <td class="px-6 py-4 text-slate-600">@pais.CodigoMoneda</td>
                        <td class="px-6 py-4 text-slate-600">@pais.SimboloMoneda</td>
                        <td class="px-6 py-4">
                            <span class="rounded-full px-3 py-1 text-xs font-bold uppercase tracking-[0.15em] @(pais.EstaActivo ? "bg-emerald-100 text-emerald-700" : "bg-slate-200 text-slate-600")">@(pais.EstaActivo ? "Activo" : "Inactivo")</span>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex justify-end gap-2">
                                <a asp-action="Editar" asp-route-id="@pais.Id" class="rounded-xl border border-slate-200 px-4 py-2 font-semibold text-slate-700 transition hover:border-mar hover:text-mar">Editar</a>
                                <a asp-action="Eliminar" asp-route-id="@pais.Id" class="rounded-xl border border-rose-200 px-4 py-2 font-semibold text-rose-700 transition hover:bg-rose-50">Eliminar</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</section>
