@model ElectronicaVallarta.Models.ErrorViewModel

@{
    ViewData["Title"] = "Error";
}

<section class="mx-auto max-w-3xl space-y-6 rounded-[2rem] border border-white/70 bg-white/90 p-8 text-center shadow-panel sm:p-10">
    <div class="inline-flex self-center rounded-full bg-rose-100 px-4 py-2 text-xs font-bold uppercase tracking-[0.22em] text-rojoMarca">
        Error del sistema
    </div>
    <div class="space-y-3">
        <h1 class="text-4xl font-black text-tinta sm:text-5xl">Ocurrio un problema al procesar la solicitud</h1>
        <p class="mx-auto max-w-2xl text-sm leading-7 text-slate-600 sm:text-base">
            Intenta nuevamente en unos minutos. Si el problema persiste, revisa la configuracion del sistema o contacta al administrador.
        </p>
    </div>

    @if (Model.ShowRequestId)
    {
        <p class="rounded-2xl bg-slate-50 px-4 py-3 text-center text-sm text-slate-500 mx-auto max-w-2xl  ">
            Id de seguimiento: <span class="font-semibold text-tinta">@Model.RequestId</span>
        </p>
    }

    <div class="flex flex-wrap justify-center gap-3">
        <a asp-controller="Home" asp-action="Index" class="rounded-2xl bg-tinta px-5 py-3 text-sm font-bold text-white transition hover:bg-mar">
            Volver al inicio
        </a>
    </div>
</section>
